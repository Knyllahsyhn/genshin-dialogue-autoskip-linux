# Genshin autoskip configuration.
# Copy this file to .env and adjust values. Every key is optional;
# missing keys fall back to built-in defaults. Real environment
# variables with the same names override this file. No quotes needed.

# Desktop notifications on status changes (true/false)
NOTIFICATIONS=true

# Automatically confirm the first answer option (true/false).
# When false, the tool waits during answer options so you can pick one yourself.
AUTO_CONFIRM=true

# RGB color of the dialogue autoplay icon (compare with calibrate output)
PLAYING_ICON_COLOR=236,229,216

# Allowed per-channel color deviation (0-255)
COLOR_TOLERANCE=10

# Checkpoint coordinates in 1920x1080 reference space (x,y).
# They are scaled to your actual window size automatically.
CHECKPOINT_PLAYING_ICON=84,46
CHECKPOINT_DIALOGUE_ICON_LOWER=1301,808
CHECKPOINT_DIALOGUE_ICON_HIGHER=1301,790
CHECKPOINT_LOADING_SCREEN=1200,700
